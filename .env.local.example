# OpenAI — kept for reference but no longer used by default
# OPENAI_API_KEY=sk-...

# Gemini — https://aistudio.google.com/apikey (primary · free 1,500 req/day)
GOOGLE_GENERATIVE_AI_API_KEY=AQ...

# Groq — https://console.groq.com/keys (fallback · free 14,400 req/day)
GROQ_API_KEY=xai-...

# Supabase — Settings → API in your project dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — https://resend.com/api-keys
# Verify noracomply.eu under Domains first; until then use onboarding@resend.dev as `from`
RESEND_API_KEY=re_...
